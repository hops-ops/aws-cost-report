# code: language=yaml
#
# Update XR status
#

{{- $xr := getCompositeResource . }}
{{- $s := $state.status }}
---
apiVersion: {{ $xr.apiVersion }}
kind: {{ $xr.kind }}
status:
  ready: {{ $s.ready }}
  bucketName: {{ $s.bucketName }}
  bucketArn: {{ $s.bucketArn }}
  databaseName: {{ $s.databaseName }}
  workgroupName: {{ $s.workgroupName }}
  crawlerRoleArn: {{ $s.crawlerRoleArn }}
